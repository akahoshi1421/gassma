{
  "name": "gassma",
  "version": "0.9.0",
  "description": "GASsma is Google Apps Script(GAS) of SpreadSheet library that can be used like prisma.",
  "types": "src/index.d.ts",
  "scripts": {
    "build": "webpack",
    "push": "npm run build && clasp push",
    "test": "jest",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "prepare": "husky"
  },
  "author": "akahoshi1421",
  "license": "MIT",
  "dependencies": {
    "@types/google-apps-script": "^1.0.83"
  },
  "keywords": [
    "Google Apps Script",
    "TypeScript",
    "JavaScript",
    "GASsma"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.2.6",
    "@types/jest": "^29.5.14",
    "gas-webpack-plugin": "^2.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.4",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "biome format --write",
      "biome lint --write"
    ]
  }
}
